---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import ProductCard from "@/components/ProductCard.astro";
import { categories, products } from "@/data/products";

const categoryGroups = categories.map((category) => ({
  category,
  products: products.filter((product) => product.category === category),
}));
---

<BaseLayout
  title="UUfinds Spreadsheet Categories | UU Find Hub"
  description="Browse UUfinds Spreadsheet categories, including sneakers, outerwear, hoodies, pants, accessories, electronics, and Maison Looks shopping links."
>
  <Header />
  <main class="bg-[#06152f] text-white" data-i18n-title="titleCategories" data-i18n-description="descriptionCategories">
    <section class="mx-auto max-w-5xl px-4 py-8 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-wide text-sky-300" data-i18n="browseByCategory">Browse by category</p>
        <h1 class="mt-2 text-3xl font-black text-white" data-i18n="categoriesHeading">UUfinds Spreadsheet Categories</h1>
      </div>

      <div class="mt-8 grid gap-6 md:grid-cols-2">
        {categoryGroups.map((group) => (
          <section class="rounded-2xl bg-white/8 p-4 shadow-sm ring-1 ring-white/10">
            <div class="mb-4 flex items-center justify-between gap-4">
              <h2 class="text-lg font-black text-white" data-i18n-auto>{group.category}</h2>
              <a href={`/categories/${group.category.toLowerCase()}`} class="text-sm font-semibold text-white/68 hover:text-white" data-i18n="seeMore">See more</a>
            </div>
            <div class="grid grid-cols-3 gap-3">
              {group.products.slice(0, 6).map((product) => <ProductCard product={product} />)}
            </div>
          </section>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
