---
import { languages } from "@/i18n/languages";

const nav = [
  { key: "home", label: "Home", href: "/" },
  { key: "spreadsheet", label: "Spreadsheet", href: "/uufinds-spreadsheet/" },
  { key: "all", label: "All", href: "/all/" },
  { key: "categories", label: "Categories", href: "/categories/" },
  { key: "guides", label: "Guides", href: "/guides/" },
  { key: "blog", label: "Blog", href: "/blog/" },
  { key: "faq", label: "FAQ", href: "/faq/" },
];
---

<header class="sticky top-0 z-40 border-b border-white/10 bg-[#06152f]/95 text-white backdrop-blur">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-2.5 sm:px-6 lg:px-8">
    <a href="/" class="flex min-h-11 items-center gap-2 font-semibold tracking-normal">
      <img
        src="/images/uufinds-spreadsheet-icon.png"
        alt="UUfinds Spreadsheet"
        class="size-9 rounded-md object-cover"
        width="36"
        height="36"
      />
      <span>UUfinds Spreadsheet</span>
    </a>
    <nav class="hidden items-center gap-5 text-sm font-medium text-white/72 md:flex">
      {nav.map((item) => <a class="transition hover:text-white" href={item.href} data-i18n={item.key}>{item.label}</a>)}
    </nav>
    <div class="flex items-center gap-2">
      <details class="group relative">
        <summary class="flex min-h-10 cursor-pointer list-none items-center gap-2 rounded-sm border border-white/10 px-3 text-sm font-semibold text-white/80 transition hover:border-sky-300/60 hover:text-white focus:outline-none focus:ring-2 focus:ring-sky-300 focus:ring-offset-2 focus:ring-offset-[#06152f]">
          <svg class="size-4" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M2 12h20"></path>
            <path d="M12 2a15.3 15.3 0 0 1 0 20"></path>
            <path d="M12 2a15.3 15.3 0 0 0 0 20"></path>
          </svg>
          <span class="hidden sm:inline" data-i18n="language">Language</span>
          <span class="sm:hidden" data-language-label>English</span>
          <svg class="size-4 transition group-open:rotate-180" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="m6 9 6 6 6-6"></path>
          </svg>
        </summary>
        <div class="absolute right-0 mt-2 grid max-h-[70vh] w-[min(92vw,440px)] grid-cols-2 gap-1 overflow-auto rounded-lg border border-white/10 bg-[#0b1d3d] p-2 text-sm text-white/78 shadow-2xl">
          {languages.map((language) => (
            <button
              type="button"
              class="rounded-md px-3 py-2 text-left font-medium transition hover:bg-white/10 hover:text-white"
              data-language-option={language.code}
              aria-selected={language.code === "en" ? "true" : "false"}
            >
              {language.label}
            </button>
          ))}
        </div>
      </details>
      <a
        href="https://streetstyle.maisonlooks.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden min-h-10 items-center rounded-sm bg-sky-400 px-4 text-sm font-semibold text-slate-950 transition hover:bg-sky-300 focus:outline-none focus:ring-2 focus:ring-sky-300 focus:ring-offset-2 focus:ring-offset-[#06152f] sm:inline-flex"
        data-i18n="openShop"
      >
        Open shop
      </a>
    </div>
  </div>
</header>
