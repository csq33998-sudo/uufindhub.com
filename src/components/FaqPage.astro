---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import { faqGroups, quickTopics, slugify } from "@/data/faq";

type Props = {
  activeSection?: string;
};

const { activeSection } = Astro.props;
const activeGroup = activeSection
  ? faqGroups.find((group) => slugify(group.title) === activeSection)
  : undefined;
const orderedGroups = activeSection
  ? [
      ...faqGroups.filter((group) => slugify(group.title) === activeSection),
      ...faqGroups.filter((group) => slugify(group.title) !== activeSection),
    ]
  : faqGroups;
const pageTitle = activeGroup ? `${activeGroup.title} FAQ | UUfinds Spreadsheet` : "UUfinds Spreadsheet FAQ | UU Find Hub";
const pageDescription = activeGroup
  ? `${activeGroup.title} questions for UUfinds Spreadsheet buyers, covering ${activeGroup.items
      .map((item) => item.question.replace(/\?$/, "").toLowerCase())
      .slice(0, 3)
      .join(", ")}.`
  : "Frequently asked questions about the UUfinds Spreadsheet, QC checks, agents, product links, and safer Maison Looks shopping workflows.";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
>
  <Header />
  <main
    class="min-h-screen bg-[#06152f] text-white"
    data-i18n-title={activeSection ? undefined : "titleFaq"}
    data-i18n-description={activeSection ? undefined : "descriptionFaq"}
  >
    <section class="border-b border-white/10 bg-[#08204a]">
      <div class="mx-auto grid max-w-6xl gap-8 px-4 py-12 sm:px-6 lg:grid-cols-[0.85fr_1.15fr] lg:px-8">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-sky-300" data-i18n-auto>Help center</p>
          <h1 class="mt-3 text-4xl font-black leading-tight text-white sm:text-5xl" data-i18n-auto>UUfinds Spreadsheet FAQ</h1>
          <p class="mt-4 max-w-xl text-sm leading-7 text-white/72" data-i18n-auto>
            Answers for browsing UUfinds Spreadsheet finds, reading QC photos, checking links, and making cleaner buying decisions before you order.
          </p>
        </div>
        <div class="grid gap-3 sm:grid-cols-2">
          {quickTopics.map((topic) => {
            const active = topic.section === activeSection;
            return (
              <a
                href={topic.href}
                class:list={[
                  "rounded-lg border px-4 py-3 text-sm font-semibold transition",
                  active
                    ? "border-sky-300/70 bg-sky-400/20 text-white"
                    : "border-white/10 bg-white/8 text-white/86 hover:border-sky-300/70 hover:bg-white/12",
                ]}
                data-i18n-auto
              >
                {topic.label}
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-5xl px-4 py-10 sm:px-6 lg:px-8">
      <div class="grid gap-8">
        {orderedGroups.map((group) => {
          const section = slugify(group.title);
          return (
            <section id={section} class="scroll-mt-24">
              <div class="mb-4 flex items-end justify-between gap-4 border-b border-white/10 pb-3">
                <h2 class="text-2xl font-black text-white" data-i18n-auto>{group.title}</h2>
                <span class="text-xs font-semibold uppercase tracking-wide text-white/45" data-i18n-auto>{group.items.length} answers</span>
              </div>
              <div class="grid gap-3">
                {group.items.map((item) => (
                  <details class="group rounded-lg border border-white/10 bg-white/8 p-4 shadow-sm open:border-sky-300/50 open:bg-white/10">
                    <summary class="flex cursor-pointer list-none items-start justify-between gap-4 text-base font-bold text-white">
                      <span data-i18n-auto>{item.question}</span>
                      <span class="mt-1 text-sky-300 transition group-open:rotate-45" aria-hidden="true">+</span>
                    </summary>
                    <p class="mt-3 text-sm leading-7 text-white/70" data-i18n-auto>{item.answer}</p>
                  </details>
                ))}
              </div>
            </section>
          );
        })}
      </div>
    </section>
  </main>
</BaseLayout>
