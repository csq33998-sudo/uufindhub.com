---
import type { Product } from "@/data/products";

type Props = {
  product: Product;
};

const { product } = Astro.props;
const productValues = JSON.stringify({ product: product.name });
---

<article class="group">
  <a
    href={product.href}
    class="block"
    aria-label={`View ${product.name} on Maison Looks`}
    data-i18n-attrs="aria-label"
    data-i18n-aria-label="ariaProduct"
    data-i18n-values={productValues}
    target="_blank"
    rel="noopener noreferrer"
  >
    <div class="aspect-square overflow-hidden rounded-lg bg-zinc-100 shadow-sm ring-1 ring-zinc-200 transition group-hover:-translate-y-0.5 group-hover:shadow-md">
      <img
        src={product.image}
        alt={product.name}
        class="h-full w-full object-cover transition duration-200 group-hover:scale-[1.03]"
        loading={product.featured ? "eager" : "lazy"}
      />
    </div>
  </a>
</article>
