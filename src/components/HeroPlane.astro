---
---

<section class="relative overflow-hidden bg-[#06152f] text-white">
  <div class="absolute inset-0 hero-bg" aria-hidden="true"></div>
  <img
    src="/images/hero-shipping.png"
    alt=""
    class="absolute inset-0 hidden h-full w-full object-cover object-[center_42%] opacity-82 md:block"
    loading="eager"
    decoding="async"
    aria-hidden="true"
  />
  <div class="absolute inset-0 bg-gradient-to-r from-[#06152f]/90 via-[#06152f]/58 to-[#06152f]/12" aria-hidden="true"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-[#06152f] via-transparent to-transparent" aria-hidden="true"></div>
  <div class="absolute inset-x-0 bottom-0 h-28 bg-gradient-to-t from-[#06152f] to-transparent" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto grid min-h-[520px] max-w-6xl items-center gap-8 px-4 py-12 sm:px-6 md:grid-cols-[0.9fr_1.1fr] lg:px-8">
    <div class="max-w-xl">
      <p class="text-sm font-bold uppercase tracking-wide text-sky-300" data-i18n="heroEyebrow">UUfinds spreadsheet hub</p>
      <h1 class="mt-3 text-4xl font-black leading-tight text-white sm:text-5xl lg:text-6xl" data-i18n="heroTitle">
        UUfinds Spreadsheet
      </h1>
      <p class="mt-5 max-w-lg text-base leading-7 text-white/72" data-i18n="heroBody">
        Browse curated UUfinds Spreadsheet finds, QC photo checks, category pages, and shopping links before continuing to Maison Looks.
      </p>
      <a
        href="https://streetstyle.maisonlooks.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-7 inline-flex min-h-12 items-center rounded-full bg-sky-400 px-7 text-sm font-semibold text-slate-950 transition hover:bg-sky-300 focus:outline-none focus:ring-2 focus:ring-sky-300 focus:ring-offset-2 focus:ring-offset-[#06152f]"
        data-i18n="heroCta"
      >
        Open UUfinds Spreadsheet
      </a>
    </div>

    <div class="relative min-h-[300px] overflow-hidden rounded-lg border border-white/10 shadow-2xl md:hidden" aria-hidden="true">
      <img
        src="/images/hero-shipping.png"
        alt=""
        class="h-full min-h-[300px] w-full object-cover object-center"
        loading="eager"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-[#06152f]/80 via-transparent to-transparent"></div>
    </div>
  </div>

  <div class="relative z-10 mx-auto max-w-4xl px-4 pb-10 sm:px-6 lg:px-8">
    <form
      class="flex flex-col gap-3 rounded-lg border border-amber-200/70 bg-amber-200/10 p-2 shadow-[0_0_18px_rgba(253,224,71,0.42),0_0_44px_rgba(251,191,36,0.26),inset_0_0_18px_rgba(253,224,71,0.12),0_18px_45px_rgba(2,6,23,0.24)] backdrop-blur sm:flex-row"
      data-maison-search
      data-i18n-attrs="aria-label"
      data-i18n-aria-label="searchLabel"
      aria-label="Search Maison Looks"
    >
      <label class="sr-only" for="maison-search" data-i18n="searchLabel">Search Maison Looks</label>
      <input
        id="maison-search"
        name="q"
        type="search"
        required
        autocomplete="off"
        placeholder="Search products, brands, or categories"
        class="min-h-12 flex-1 rounded-md border border-white/10 bg-[#071c3d] px-4 text-sm font-semibold text-white placeholder:text-white/45 transition focus:border-sky-300 focus:outline-none focus:ring-2 focus:ring-sky-300/45"
        data-i18n-attrs="placeholder"
        data-i18n-placeholder="searchPlaceholder"
      />
      <button
        type="submit"
        class="inline-flex min-h-12 items-center justify-center rounded-md bg-sky-400 px-6 text-sm font-black text-slate-950 transition hover:bg-sky-300 focus:outline-none focus:ring-2 focus:ring-sky-300 focus:ring-offset-2 focus:ring-offset-[#06152f]"
        data-i18n="searchButton"
      >
        Search
      </button>
    </form>
  </div>
</section>

<script is:inline>
  document.addEventListener("submit", (event) => {
    if (!(event.target instanceof HTMLFormElement) || !event.target.matches("[data-maison-search]")) {
      return;
    }

    event.preventDefault();
    const query = String(new FormData(event.target).get("q") || "").trim();
    if (!query) {
      return;
    }

    window.open(
      `https://streetstyle.maisonlooks.com/en/search?q=${encodeURIComponent(query)}`,
      "_blank",
      "noopener,noreferrer",
    );
  });
</script>

<style>
  .hero-bg {
    background:
      radial-gradient(circle at 74% 16%, rgba(125, 211, 252, 0.14) 0 9%, transparent 10%),
      linear-gradient(180deg, #0b2a58 0%, #071c3d 62%, #06152f 100%);
  }
</style>
