---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import { blogCategories, blogPosts } from "@/data/blog";

const featuredPosts = blogPosts.slice(0, 2);
const groupedPosts = blogCategories.map((category) => ({
  category,
  posts: blogPosts.filter((post) => post.category === category),
}));
---

<BaseLayout
  title="UUfinds Spreadsheet Blog | QC, Finds, Links and Buying Guides"
  description="Read the UUfinds Spreadsheet blog for QC photo checks, spreadsheet workflows, product link tips, streetwear finds, and safer agent-order habits."
>
  <Header />
  <main
    class="min-h-screen bg-[#06152f] text-white"
    data-i18n-title="titleBlog"
    data-i18n-description="descriptionBlog"
  >
    <section class="border-b border-white/10 bg-[#08204a]">
      <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-3xl text-center">
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-sky-300" data-i18n="blogEyebrow">Buyer notes</p>
          <h1 class="mt-3 text-4xl font-black leading-tight text-white sm:text-5xl" data-i18n="blogTitle">
            UUfinds Spreadsheet Blog
          </h1>
          <p class="mt-4 max-w-xl text-sm leading-7 text-white/72" data-i18n="blogIntro">
            Practical notes for using spreadsheet finds, checking QC photos, handling product links, and making cleaner agent-order decisions.
          </p>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
      <div class="mb-8 flex flex-wrap items-end justify-between gap-4 border-b border-white/10 pb-4">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-sky-300" data-i18n="blogLatest">Latest posts</p>
          <h2 class="mt-2 text-2xl font-black text-white" data-i18n="blogTopics">Spreadsheet and QC topics</h2>
        </div>
        <a
          href="/faq/spreadsheets/"
          class="text-sm font-semibold text-white/68 transition hover:text-white"
          data-i18n="blogFaqLink"
        >
          Spreadsheet FAQ
        </a>
      </div>

      <div class="grid gap-6 lg:grid-cols-2">
        {featuredPosts.map((post) => (
          <article class="overflow-hidden rounded-lg border border-white/10 bg-white/8 shadow-xl shadow-slate-950/20 transition hover:border-sky-300/45">
            <img src={post.image} alt="" class="aspect-[16/9] w-full object-cover" loading="lazy" />
            <div class="p-5">
              <div class="flex flex-wrap items-center gap-2 text-xs font-bold uppercase tracking-wide text-sky-200/75">
                <span>{post.category}</span>
                <span class="text-white/25">/</span>
                <span>{post.date}</span>
                <span class="text-white/25">/</span>
                <span>{post.readTime}</span>
              </div>
              <h2 class="mt-3 text-2xl font-black leading-tight text-white">{post.title}</h2>
              <p class="mt-3 text-sm leading-7 text-white/72">{post.excerpt}</p>
              <p class="mt-4 text-sm leading-7 text-white/68">{post.body}</p>
              <div class="mt-4 grid gap-2">
                {post.steps.map((step) => (
                  <p class="rounded-md border border-white/10 bg-[#071c3d] px-3 py-2 text-sm leading-6 text-white/72">{step}</p>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="mx-auto grid max-w-6xl gap-10 px-4 pb-14 sm:px-6 lg:px-8">
      {groupedPosts.map((group) => (
        <section id={group.category.toLowerCase().replaceAll(" ", "-")} class="scroll-mt-24">
          <div class="mb-5 flex items-center justify-between gap-4 border-b border-white/10 pb-3">
            <h2 class="text-2xl font-black text-white">{group.category}</h2>
            <span class="text-xs font-bold uppercase tracking-wide text-white/45">{group.posts.length} posts</span>
          </div>
          <div class="grid gap-5 md:grid-cols-2">
            {group.posts.map((post) => (
              <article class="grid gap-4 rounded-lg border border-white/10 bg-white/8 p-4 shadow-sm transition hover:border-sky-300/45 hover:bg-white/10 sm:grid-cols-[150px_1fr]">
                <img src={post.image} alt="" class="aspect-[4/3] w-full rounded-md object-cover" loading="lazy" />
                <div>
                  <div class="flex flex-wrap items-center gap-2 text-xs font-bold uppercase tracking-wide text-sky-200/75">
                    <span>{post.date}</span>
                    <span class="text-white/25">/</span>
                    <span>{post.readTime}</span>
                  </div>
                  <h3 class="mt-2 text-lg font-black leading-tight text-white">{post.title}</h3>
                  <p class="mt-2 text-sm leading-6 text-white/70">{post.excerpt}</p>
                </div>
              </article>
            ))}
          </div>
        </section>
      ))}
    </section>
  </main>
</BaseLayout>
