---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import ProductCard from "@/components/ProductCard.astro";
import { products } from "@/data/products";
---

<BaseLayout
  title="All UUfinds Spreadsheet Finds | UU Find Hub"
  description="Browse every curated UUfinds Spreadsheet find, including product images, QC-style checks, category shortcuts, and external product links."
>
  <Header />
  <main class="bg-[#06152f] text-white" data-i18n-title="titleAll" data-i18n-description="descriptionAll">
    <section class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
      <div class="border-b border-white/10 pb-4">
        <p class="text-sm font-semibold uppercase tracking-wide text-sky-300" data-i18n="allFinds">All finds</p>
        <h1 class="mt-2 text-3xl font-black text-white" data-i18n="allProducts">All UUfinds Spreadsheet Finds</h1>
        <p class="mt-2 text-sm text-white/68"><span>{products.length}</span> <span data-i18n="allCountSuffix">curated UUfinds Spreadsheet rows with external product links.</span></p>
      </div>

      <div class="mt-6 grid grid-cols-3 gap-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-7">
        {products.map((product) => <ProductCard product={product} />)}
      </div>
    </section>
  </main>
</BaseLayout>
